{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fieldconnect.onrender.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fieldconnect.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fieldconnect.onrender.com",
        "EXPO_PUBLIC_SENTRY_DSN": "https://***REMOVED***/4510837322285056",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "NPM_CONFIG_UNSAFE_PERM": "true",
        "npm_config_unsafe_perm": "true"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "uluckaan97@hotmail.com",
        "ascAppId": "6758695571"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
