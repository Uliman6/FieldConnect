{
  "expo": {
    "name": "FieldConnect",
    "slug": "fieldconnect",
    "scheme": "fieldconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.const.fieldconnect",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FieldConnect needs microphone access to record voice notes for daily logs and events.",
        "NSCameraUsageDescription": "FieldConnect needs camera access to take photos for punch lists and documentation.",
        "NSPhotoLibraryUsageDescription": "FieldConnect needs photo library access to attach existing photos to your reports.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.const.fieldconnect",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-updates",
      "@sentry/react-native/expo",
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "FieldConnect needs microphone access to record voice notes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FieldConnect needs camera access to take photos for documentation.",
          "microphonePermission": "FieldConnect needs microphone access to record audio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FieldConnect needs access to your photos to attach images to reports."
        }
      ],
      "expo-asset",
      "expo-localization",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "8697f118-69e2-4cc2-a676-80d0a0591aa0"
      },
      "router": {}
    },
    "owner": "ulis-organization",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/8697f118-69e2-4cc2-a676-80d0a0591aa0",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    }
  }
}