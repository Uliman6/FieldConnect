// Prisma Schema for Construction Daily Log & Event Intelligence System
// Supports full-text search on PostgreSQL

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION
// ============================================

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================
// CORE ENTITIES
// ============================================

model Project {
  id        String   @id @default(uuid())
  name      String
  number    String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  dailyLogs       DailyLog[]
  events          Event[]
  insights        Insight[]
  templates       PdfTemplate[]
  documentSchemas DocumentSchema[]

  @@index([name])
  @@index([number])
  @@map("projects")
}

model DailyLog {
  id                 String   @id @default(uuid())
  projectId          String   @map("project_id")
  date               DateTime @db.Date
  preparedBy         String?  @map("prepared_by")
  status             String?  @default("draft")
  dailyTotalsWorkers Int?     @map("daily_totals_workers")
  dailyTotalsHours   Float?   @map("daily_totals_hours")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  // Weather as JSON (flexible structure)
  weather Json?

  // Relations
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                Task[]
  visitors             Visitor[]
  equipment            Equipment[]
  materials            Material[]
  pendingIssues        PendingIssue[]
  inspectionNotes      InspectionNote[]
  additionalWorkEntries AdditionalWorkEntry[]

  @@index([projectId])
  @@index([date])
  @@index([status])
  @@map("daily_logs")
}

// ============================================
// DAILY LOG NESTED ENTITIES
// ============================================

model Task {
  id              String  @id @default(uuid())
  dailyLogId      String  @map("daily_log_id")
  companyName     String? @map("company_name")
  workers         Int?
  hours           Float?
  taskDescription String? @map("task_description") @db.Text
  notes           String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([companyName])
  @@map("tasks")
}

model Visitor {
  id          String  @id @default(uuid())
  dailyLogId  String  @map("daily_log_id")
  time        String?
  companyName String? @map("company_name")
  visitorName String? @map("visitor_name")
  notes       String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("visitors")
}

model Equipment {
  id            String  @id @default(uuid())
  dailyLogId    String  @map("daily_log_id")
  equipmentType String? @map("equipment_type")
  quantity      Int?
  hours         Float?
  notes         String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("equipment")
}

model Material {
  id         String  @id @default(uuid())
  dailyLogId String  @map("daily_log_id")
  material   String?
  quantity   Float?
  unit       String?
  supplier   String?
  notes      String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([supplier])
  @@map("materials")
}

model PendingIssue {
  id             String   @id @default(uuid())
  dailyLogId     String   @map("daily_log_id")
  title          String?
  description    String?  @db.Text
  category       String?
  severity       String?
  assignee       String?
  dueDate        DateTime? @map("due_date") @db.Date
  externalEntity String?  @map("external_entity")
  location       String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([category])
  @@index([severity])
  @@index([assignee])
  @@map("pending_issues")
}

model InspectionNote {
  id             String   @id @default(uuid())
  dailyLogId     String   @map("daily_log_id")
  inspectorName  String?  @map("inspector_name")
  ahj            String?  // Authority Having Jurisdiction
  inspectionType String?  @map("inspection_type")
  result         String?
  notes          String?  @db.Text
  followUpNeeded Boolean? @map("follow_up_needed")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([inspectorName])
  @@index([inspectionType])
  @@index([result])
  @@map("inspection_notes")
}

model AdditionalWorkEntry {
  id          String  @id @default(uuid())
  dailyLogId  String  @map("daily_log_id")
  category    String?
  description String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([category])
  @@map("additional_work_entries")
}

// ============================================
// EVENTS (for Event Intelligence)
// ============================================

model Event {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  transcriptText String?   @map("transcript_text") @db.Text
  eventType      String?   @map("event_type")
  severity       String?
  title          String?
  description    String?   @db.Text  // Clean, professional summary of the event
  notes          String?   @db.Text  // Additional user notes
  location       String?
  tradeVendor    String?   @map("trade_vendor")
  isResolved     Boolean?  @default(false) @map("is_resolved")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  // Link to audio file if exists
  audioFileId String? @map("audio_file_id")

  // Link to daily log if event was added to one
  linkedDailyLogId String? @map("linked_daily_log_id")

  // Link to PDF template if using structured form
  templateId String? @map("template_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template PdfTemplate? @relation(fields: [templateId], references: [id])
  templateData EventTemplateData?
  schemaData EventSchemaData?
  index   EventIndex?

  @@index([projectId])
  @@index([templateId])
  @@index([eventType])
  @@index([severity])
  @@index([tradeVendor])
  @@index([location])
  @@index([isResolved])
  @@index([createdAt])
  @@index([linkedDailyLogId])
  @@map("events")
}

// ============================================
// EVENT INDEX (Searchable Keywords)
// ============================================

model EventIndex {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Extracted entities stored as JSON arrays for flexible querying
  inspectors     Json?    // ["John Nathan", "Jignesh Molan"]
  trades         Json?    // ["electricians", "plumbers", "BMS"]
  materials      Json?    // ["Oil Flow", "metal panels", "concrete"]
  issueTypes     Json?    // ["cost_impact", "code_violation", "rework"]
  locations      Json?    // ["level 1", "fire command center", "roof"]
  ahj            Json?    // Authority Having Jurisdiction ["Santa Clara", "Santa Clara County"]
  systems        Json?    // ["BMS", "HVAC", "sprinkler", "smoke control"]
  costImpact     Float?   @map("cost_impact") // Extracted dollar amount if mentioned

  // Follow-up tracking
  needsFollowUp  Boolean  @default(false) @map("needs_follow_up")
  followUpReason String?  @map("follow_up_reason") @db.Text
  followUpDueDate DateTime? @map("follow_up_due_date")

  // Full-text searchable summary of all keywords
  keywordsSummary String? @map("keywords_summary") @db.Text

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([needsFollowUp])
  @@index([costImpact])
  @@map("event_indexes")
}

// ============================================
// UNIFIED INSIGHTS SYSTEM
// ============================================
// Captures learnings, issues, observations from all sources
// for pattern matching and proactive issue surfacing

enum InsightSourceType {
  event
  pending_issue
  inspection_note
  additional_work
  manual
}

enum InsightCategory {
  issue
  learning
  observation
  safety
  quality
  cost_impact
  delay
  rework
}

model Insight {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Source tracking - where did this insight come from?
  sourceType  InsightSourceType @map("source_type")
  sourceId    String?  @map("source_id") // Original record ID if from another table
  projectId   String   @map("project_id")
  dailyLogId  String?  @map("daily_log_id")
  dailyLogDate DateTime? @map("daily_log_date") @db.Date

  // Core content
  title       String
  description String?  @db.Text
  rawText     String?  @map("raw_text") @db.Text // Original transcript/notes

  // Classification
  category    InsightCategory @default(issue)
  severity    String?  // 'low', 'medium', 'high', 'critical'

  // Extracted entities (JSON arrays for flexible querying)
  inspectors  Json?    // ["John Nathan", "Jane Smith"]
  trades      Json?    // ["electricians", "plumbers", "HVAC"]
  materials   Json?    // ["concrete", "metal panels"]
  issueTypes  Json?    // ["cost_impact", "code_violation", "rework"]
  locations   Json?    // ["level 1", "basement", "roof"]
  ahj         Json?    // Authority Having Jurisdiction
  systems     Json?    // ["BMS", "HVAC", "sprinkler"]
  costImpact  Float?   @map("cost_impact")

  // Follow-up tracking
  needsFollowUp  Boolean  @default(false) @map("needs_follow_up")
  followUpReason String?  @map("follow_up_reason") @db.Text
  followUpDueDate DateTime? @map("follow_up_due_date")
  isResolved     Boolean  @default(false) @map("is_resolved")
  resolvedAt     DateTime? @map("resolved_at")

  // Pattern matching - full-text searchable summary
  keywordsSummary String? @map("keywords_summary") @db.Text

  // Test environment flag - separates test data from production
  isTest      Boolean  @default(false) @map("is_test")

  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType])
  @@index([sourceId])
  @@index([category])
  @@index([severity])
  @@index([needsFollowUp])
  @@index([isResolved])
  @@index([isTest])
  @@index([createdAt])
  @@index([dailyLogDate])
  @@map("insights")
}

// ============================================
// INSIGHT PATTERNS (for pattern detection)
// ============================================
// Stores detected patterns across insights for proactive alerting

model InsightPattern {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Pattern definition
  name        String   // "Recurring stair code issues"
  description String?  @db.Text
  patternType String   @map("pattern_type") // 'recurring_issue', 'trade_correlation', 'location_hotspot'

  // Matching criteria (JSON for flexibility)
  matchCriteria Json   @map("match_criteria") // {trades: ["electrician"], issueTypes: ["code_violation"]}

  // Statistics
  occurrenceCount Int  @default(0) @map("occurrence_count")
  lastSeenAt     DateTime? @map("last_seen_at")
  firstSeenAt    DateTime? @map("first_seen_at")

  // Related insights (JSON array of insight IDs)
  relatedInsightIds Json? @map("related_insight_ids")

  // Alerting
  isActive    Boolean  @default(true) @map("is_active")
  alertThreshold Int?  @map("alert_threshold") // Alert when count exceeds this

  // Test flag
  isTest      Boolean  @default(false) @map("is_test")

  @@index([patternType])
  @@index([isActive])
  @@index([isTest])
  @@map("insight_patterns")
}

// ============================================
// PDF TEMPLATE SYSTEM
// ============================================

enum TemplateType {
  PUNCH_LIST
  RFI
  CUSTOM
}

model PdfTemplate {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Template metadata
  name          String       // "Punch List v2", "RFI Form"
  description   String?      @db.Text
  templateType  TemplateType @map("template_type")
  version       Int          @default(1)
  isActive      Boolean      @default(true) @map("is_active")

  // Project-specific template (null = admin/default template)
  projectId     String?      @map("project_id")

  // File storage
  fileName      String       @map("file_name")
  filePath      String       @map("file_path")  // ./uploads/templates/uuid.pdf
  fileSize      Int          @map("file_size")

  // Extracted form fields (JSON structure)
  // Format: [{ name: "field1", type: "text", label: "Field 1", required: false }, ...]
  formFields    Json         @map("form_fields")

  // Creator tracking
  createdById   String?      @map("created_by_id")

  // Relations
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events        Event[]
  templateData  EventTemplateData[]

  @@index([templateType])
  @@index([isActive])
  @@index([projectId])
  @@map("pdf_templates")
}

// Stores filled template field values for each event
model EventTemplateData {
  id               String     @id @default(uuid())
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  eventId          String     @unique @map("event_id")
  templateId       String     @map("template_id")

  // Field values as JSON: { "fieldName1": "value1", "fieldName2": "value2" }
  fieldValues      Json       @map("field_values")

  // Generated PDF path (after filling)
  generatedPdfPath String?    @map("generated_pdf_path")

  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template         PdfTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@map("event_template_data")
}

// ============================================
// IMPORT TRACKING
// ============================================

model ImportLog {
  id              String   @id @default(uuid())
  filename        String
  importedAt      DateTime @default(now()) @map("imported_at")
  projectsCreated Int      @default(0) @map("projects_created")
  logsImported    Int      @default(0) @map("logs_imported")
  eventsImported  Int      @default(0) @map("events_imported")
  status          String   @default("completed")
  errorMessage    String?  @map("error_message") @db.Text

  @@map("import_logs")
}

// ============================================
// DOCUMENT SCHEMA LEARNING
// ============================================
// Stores learned field structures from sample documents
// Used to understand what data to extract from events/transcriptions

enum SchemaDocumentType {
  PUNCH_LIST
  RFI
  DAILY_REPORT
  SAFETY_REPORT
  INSPECTION
  CUSTOM
}

model DocumentSchema {
  id             String             @id @default(uuid())
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // Schema metadata
  name           String             // "Punch List", "RFI Form"
  description    String?            @db.Text
  documentType   SchemaDocumentType @map("document_type")
  version        Int                @default(1)
  isActive       Boolean            @default(true) @map("is_active")

  // Project association (null = global/default schema)
  projectId      String?            @map("project_id")

  // Source document info
  sourceFileName String?            @map("source_file_name")
  sourceFilePath String?            @map("source_file_path")

  // Learned field structure (JSON)
  // Format: [{ name, type, label, description, required, examples }]
  fields         Json               @default("[]")

  // AI analysis metadata
  analysisNotes  String?            @map("analysis_notes") @db.Text
  confidence     Float?             // AI confidence score 0-1

  // Relations
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventSchemaData EventSchemaData[]

  @@index([projectId])
  @@index([documentType])
  @@index([isActive])
  @@map("document_schemas")
}

// ============================================
// EVENT SCHEMA DATA (Extracted Document Fields)
// ============================================
// Stores extracted field values when user applies a document schema to an event
// Enables: Event -> "Apply to Document" -> AI extracts fields -> User edits -> Save

model EventSchemaData {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  eventId       String         @unique @map("event_id")
  schemaId      String         @map("schema_id")

  // Extracted/edited field values as JSON: { "title": "...", "description": "...", etc }
  fieldValues   Json           @map("field_values") @default("{}")

  // Extraction metadata
  extractedAt   DateTime?      @map("extracted_at")
  extractionConfidence Float?  @map("extraction_confidence") // AI confidence 0-1

  // Track manual edits
  lastEditedAt  DateTime?      @map("last_edited_at")
  wasManuallyEdited Boolean    @default(false) @map("was_manually_edited")

  // Generated PDF
  generatedPdfPath String?     @map("generated_pdf_path")
  generatedPdfName String?     @map("generated_pdf_name")
  pdfGeneratedAt   DateTime?   @map("pdf_generated_at")

  // Relations
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  schema        DocumentSchema @relation(fields: [schemaId], references: [id])

  @@index([schemaId])
  @@map("event_schema_data")
}
