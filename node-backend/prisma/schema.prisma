// Prisma Schema for Construction Daily Log & Event Intelligence System
// Supports full-text search on PostgreSQL

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & MULTI-TENANCY
// ============================================

enum Role {
  ADMIN       // System admin - can manage all companies
  EDITOR      // Legacy - being replaced by ProjectRole
  VIEWER      // Legacy - being replaced by ProjectRole
}

enum ProjectRole {
  OWNER       // Full control, can delete project
  ADMIN       // Can manage project settings and members
  MEMBER      // Can create/edit content
  VIEWER      // Read-only access
}

// Item status for punch lists and RFIs
enum ItemStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

// Company/Organization for multi-tenant isolation
model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique  // URL-friendly identifier
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  projects    Project[]

  @@index([slug])
  @@index([isActive])
  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role     @default(VIEWER)  // System-wide role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Company association - users belong to one company
  companyId    String?  @map("company_id")
  company      Company? @relation(fields: [companyId], references: [id])

  // Project memberships - many-to-many through UserProject
  projectMemberships UserProject[]

  // Project invitations
  invitationsSent     ProjectInvitation[] @relation("InvitationsSent")
  invitationsAccepted ProjectInvitation[] @relation("InvitationsAccepted")

  // Maintenance visits
  maintenanceVisits   MaintenanceVisit[]

  @@index([email])
  @@index([role])
  @@index([companyId])
  @@map("users")
}

// Junction table for User-Project many-to-many with role
model UserProject {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  projectId String      @map("project_id")
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([role])
  @@map("user_projects")
}

// Project Invitations - pending invites to join a project
enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model ProjectInvitation {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  expiresAt   DateTime         @map("expires_at")

  // Invitation details
  email       String                              // Invitee email
  role        ProjectRole      @default(MEMBER)   // Role they'll have when they accept
  status      InvitationStatus @default(PENDING)
  message     String?          @db.Text           // Optional message from inviter

  // Project being invited to
  projectId   String           @map("project_id")
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Who sent the invite
  invitedById String           @map("invited_by_id")
  invitedBy   User             @relation("InvitationsSent", fields: [invitedById], references: [id])

  // If accepted, link to the user who accepted
  acceptedById String?         @map("accepted_by_id")
  acceptedBy   User?           @relation("InvitationsAccepted", fields: [acceptedById], references: [id])
  acceptedAt   DateTime?       @map("accepted_at")

  @@index([email])
  @@index([projectId])
  @@index([status])
  @@index([invitedById])
  @@map("project_invitations")
}

// ============================================
// CORE ENTITIES
// ============================================

model Project {
  id        String   @id @default(uuid())
  name      String
  number    String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  // Test project flag - insights from test projects are excluded from pattern analysis
  isTest    Boolean  @default(false) @map("is_test")

  // Company association - projects belong to one company
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id])

  // User memberships - many-to-many through UserProject
  members     UserProject[]
  invitations ProjectInvitation[]

  dailyLogs       DailyLog[]
  events          Event[]
  insights        Insight[]
  templates       PdfTemplate[]
  documentSchemas DocumentSchema[]
  voiceLists      VoiceList[]

  @@index([name])
  @@index([number])
  @@index([isTest])
  @@index([companyId])
  @@map("projects")
}

model DailyLog {
  id                 String   @id @default(uuid())
  projectId          String   @map("project_id")
  date               DateTime @db.Date
  preparedBy         String?  @map("prepared_by")
  status             String?  @default("draft")
  dailyTotalsWorkers Int?     @map("daily_totals_workers")
  dailyTotalsHours   Float?   @map("daily_totals_hours")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  // Weather as JSON (flexible structure)
  weather Json?

  // Relations
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                Task[]
  visitors             Visitor[]
  equipment            Equipment[]
  materials            Material[]
  pendingIssues        PendingIssue[]
  inspectionNotes      InspectionNote[]
  additionalWorkEntries AdditionalWorkEntry[]
  photos               Photo[]

  @@index([projectId])
  @@index([date])
  @@index([status])
  @@map("daily_logs")
}

// ============================================
// DAILY LOG NESTED ENTITIES
// ============================================

model Task {
  id              String  @id @default(uuid())
  dailyLogId      String  @map("daily_log_id")
  companyName     String? @map("company_name")
  workers         Int?
  hours           Float?
  taskDescription String? @map("task_description") @db.Text
  notes           String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([companyName])
  @@map("tasks")
}

model Visitor {
  id          String  @id @default(uuid())
  dailyLogId  String  @map("daily_log_id")
  time        String?
  companyName String? @map("company_name")
  visitorName String? @map("visitor_name")
  notes       String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("visitors")
}

model Equipment {
  id            String  @id @default(uuid())
  dailyLogId    String  @map("daily_log_id")
  equipmentType String? @map("equipment_type")
  quantity      Int?
  hours         Float?
  notes         String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@map("equipment")
}

model Material {
  id         String  @id @default(uuid())
  dailyLogId String  @map("daily_log_id")
  material   String?
  quantity   Float?
  unit       String?
  supplier   String?
  notes      String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([supplier])
  @@map("materials")
}

model PendingIssue {
  id             String   @id @default(uuid())
  dailyLogId     String   @map("daily_log_id")
  title          String?
  description    String?  @db.Text
  category       String?
  severity       String?
  assignee       String?
  dueDate        DateTime? @map("due_date") @db.Date
  externalEntity String?  @map("external_entity")
  location       String?

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([category])
  @@index([severity])
  @@index([assignee])
  @@map("pending_issues")
}

model InspectionNote {
  id             String   @id @default(uuid())
  dailyLogId     String   @map("daily_log_id")
  inspectorName  String?  @map("inspector_name")
  ahj            String?  // Authority Having Jurisdiction
  inspectionType String?  @map("inspection_type")
  result         String?
  notes          String?  @db.Text
  followUpNeeded Boolean? @map("follow_up_needed")

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([inspectorName])
  @@index([inspectionType])
  @@index([result])
  @@map("inspection_notes")
}

model AdditionalWorkEntry {
  id          String  @id @default(uuid())
  dailyLogId  String  @map("daily_log_id")
  category    String?
  description String? @db.Text

  dailyLog DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([dailyLogId])
  @@index([category])
  @@map("additional_work_entries")
}

// ============================================
// EVENTS (for Event Intelligence)
// ============================================

model Event {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  transcriptText String?   @map("transcript_text") @db.Text
  eventType      String?   @map("event_type")
  customEventType String?  @map("custom_event_type") // Custom type when eventType is "Other"
  severity       String?
  title          String?
  description    String?   @db.Text  // Clean, professional summary of the event
  notes          String?   @db.Text  // Additional user notes
  location       String?
  tradeVendor    String?   @map("trade_vendor")
  isResolved     Boolean?  @default(false) @map("is_resolved")

  // Original ID from imported JSON (for deduplication)
  originalId String? @unique @map("original_id")

  // Link to audio file if exists
  audioFileId String? @map("audio_file_id")

  // Link to daily log if event was added to one
  linkedDailyLogId String? @map("linked_daily_log_id")

  // Link to PDF template if using structured form
  templateId String? @map("template_id")

  // Checklist status workflow (for punch lists and RFIs)
  itemStatus      ItemStatus @default(OPEN) @map("item_status")
  statusChangedAt DateTime?  @map("status_changed_at")
  statusChangedBy String?    @map("status_changed_by")

  // Collaboration tracking
  version         Int        @default(1)  // For optimistic locking
  lastModifiedById String?   @map("last_modified_by_id")
  createdById     String?    @map("created_by_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template PdfTemplate? @relation(fields: [templateId], references: [id])
  templateData EventTemplateData?
  schemaData EventSchemaData?
  index   EventIndex?
  photos  Photo[]
  comments EventComment[]

  @@index([projectId])
  @@index([templateId])
  @@index([eventType])
  @@index([severity])
  @@index([tradeVendor])
  @@index([location])
  @@index([isResolved])
  @@index([itemStatus])
  @@index([createdAt])
  @@index([linkedDailyLogId])
  @@map("events")
}

// ============================================
// EVENT INDEX (Searchable Keywords)
// ============================================

model EventIndex {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Extracted entities stored as JSON arrays for flexible querying
  inspectors     Json?    // ["John Nathan", "Jignesh Molan"]
  trades         Json?    // ["electricians", "plumbers", "BMS"]
  materials      Json?    // ["Oil Flow", "metal panels", "concrete"]
  issueTypes     Json?    // ["cost_impact", "code_violation", "rework"]
  locations      Json?    // ["level 1", "fire command center", "roof"]
  ahj            Json?    // Authority Having Jurisdiction ["Santa Clara", "Santa Clara County"]
  systems        Json?    // ["BMS", "HVAC", "sprinkler", "smoke control"]
  costImpact     Float?   @map("cost_impact") // Extracted dollar amount if mentioned

  // Follow-up tracking
  needsFollowUp  Boolean  @default(false) @map("needs_follow_up")
  followUpReason String?  @map("follow_up_reason") @db.Text
  followUpDueDate DateTime? @map("follow_up_due_date")

  // Full-text searchable summary of all keywords
  keywordsSummary String? @map("keywords_summary") @db.Text

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([needsFollowUp])
  @@index([costImpact])
  @@map("event_indexes")
}

// ============================================
// EVENT COMMENTS (Revision History)
// ============================================

model EventComment {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now()) @map("created_at")
  eventId        String   @map("event_id")

  // Comment content
  text           String   @db.Text
  authorName     String?  @map("author_name")

  // Type of comment: 'comment', 'status_change', 'edit'
  commentType    String   @default("comment") @map("comment_type")

  // For status change audit trail
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")

  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
  @@map("event_comments")
}

// ============================================
// UNIFIED INSIGHTS SYSTEM
// ============================================
// Captures learnings, issues, observations from all sources
// for pattern matching and proactive issue surfacing

enum InsightSourceType {
  event
  pending_issue
  inspection_note
  additional_work
  manual
}

enum InsightCategory {
  issue
  learning
  observation
  safety
  quality
  cost_impact
  delay
  rework
}

model Insight {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Source tracking - where did this insight come from?
  sourceType  InsightSourceType @map("source_type")
  sourceId    String?  @map("source_id") // Original record ID if from another table
  projectId   String   @map("project_id")
  dailyLogId  String?  @map("daily_log_id")
  dailyLogDate DateTime? @map("daily_log_date") @db.Date

  // Core content
  title       String
  description String?  @db.Text
  rawText     String?  @map("raw_text") @db.Text // Original transcript/notes

  // Classification
  category    InsightCategory @default(issue)
  eventType   String?  @map("event_type") // Original event type (Delay, Quality, Safety, etc.)
  customType  String?  @map("custom_type") // Custom type when eventType is "Other"
  severity    String?  // 'low', 'medium', 'high', 'critical'

  // Extracted entities (JSON arrays for flexible querying)
  inspectors  Json?    // ["John Nathan", "Jane Smith"]
  trades      Json?    // ["electricians", "plumbers", "HVAC"]
  materials   Json?    // ["concrete", "metal panels"]
  issueTypes  Json?    // ["cost_impact", "code_violation", "rework"]
  locations   Json?    // ["level 1", "basement", "roof"]
  ahj         Json?    // Authority Having Jurisdiction
  systems     Json?    // ["BMS", "HVAC", "sprinkler"]
  costImpact  Float?   @map("cost_impact")

  // Follow-up tracking
  needsFollowUp  Boolean  @default(false) @map("needs_follow_up")
  followUpReason String?  @map("follow_up_reason") @db.Text
  followUpDueDate DateTime? @map("follow_up_due_date")
  isResolved     Boolean  @default(false) @map("is_resolved")
  resolvedAt     DateTime? @map("resolved_at")

  // Pattern matching - full-text searchable summary
  keywordsSummary String? @map("keywords_summary") @db.Text

  // Semantic search - OpenAI embedding vector (1536 dimensions stored as JSON)
  embedding   Json?    // Float array for cosine similarity search

  // Test environment flag - separates test data from production
  isTest      Boolean  @default(false) @map("is_test")

  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceType])
  @@index([sourceId])
  @@index([category])
  @@index([severity])
  @@index([needsFollowUp])
  @@index([isResolved])
  @@index([isTest])
  @@index([createdAt])
  @@index([dailyLogDate])
  @@map("insights")
}

// ============================================
// INSIGHT PATTERNS (for pattern detection)
// ============================================
// Stores detected patterns across insights for proactive alerting

model InsightPattern {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Pattern definition
  name        String   // "Recurring stair code issues"
  description String?  @db.Text
  patternType String   @map("pattern_type") // 'recurring_issue', 'trade_correlation', 'location_hotspot'

  // Matching criteria (JSON for flexibility)
  matchCriteria Json   @map("match_criteria") // {trades: ["electrician"], issueTypes: ["code_violation"]}

  // Statistics
  occurrenceCount Int  @default(0) @map("occurrence_count")
  lastSeenAt     DateTime? @map("last_seen_at")
  firstSeenAt    DateTime? @map("first_seen_at")

  // Related insights (JSON array of insight IDs)
  relatedInsightIds Json? @map("related_insight_ids")

  // Alerting
  isActive    Boolean  @default(true) @map("is_active")
  alertThreshold Int?  @map("alert_threshold") // Alert when count exceeds this

  // Test flag
  isTest      Boolean  @default(false) @map("is_test")

  @@index([patternType])
  @@index([isActive])
  @@index([isTest])
  @@map("insight_patterns")
}

// ============================================
// PDF TEMPLATE SYSTEM
// ============================================

enum TemplateType {
  PUNCH_LIST
  RFI
  CUSTOM
}

model PdfTemplate {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Template metadata
  name          String       // "Punch List v2", "RFI Form"
  description   String?      @db.Text
  templateType  TemplateType @map("template_type")
  version       Int          @default(1)
  isActive      Boolean      @default(true) @map("is_active")

  // Project-specific template (null = admin/default template)
  projectId     String?      @map("project_id")

  // File storage
  fileName      String       @map("file_name")
  filePath      String       @map("file_path")  // ./uploads/templates/uuid.pdf
  fileSize      Int          @map("file_size")

  // Extracted form fields (JSON structure)
  // Format: [{ name: "field1", type: "text", label: "Field 1", required: false }, ...]
  formFields    Json         @map("form_fields")

  // Creator tracking
  createdById   String?      @map("created_by_id")

  // Relations
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events        Event[]
  templateData  EventTemplateData[]

  @@index([templateType])
  @@index([isActive])
  @@index([projectId])
  @@map("pdf_templates")
}

// Stores filled template field values for each event
model EventTemplateData {
  id               String     @id @default(uuid())
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  eventId          String     @unique @map("event_id")
  templateId       String     @map("template_id")

  // Field values as JSON: { "fieldName1": "value1", "fieldName2": "value2" }
  fieldValues      Json       @map("field_values")

  // Generated PDF path (after filling)
  generatedPdfPath String?    @map("generated_pdf_path")

  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template         PdfTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@map("event_template_data")
}

// ============================================
// IMPORT TRACKING
// ============================================

model ImportLog {
  id              String   @id @default(uuid())
  filename        String
  importedAt      DateTime @default(now()) @map("imported_at")
  projectsCreated Int      @default(0) @map("projects_created")
  logsImported    Int      @default(0) @map("logs_imported")
  eventsImported  Int      @default(0) @map("events_imported")
  status          String   @default("completed")
  errorMessage    String?  @map("error_message") @db.Text

  @@map("import_logs")
}

// ============================================
// DOCUMENT SCHEMA LEARNING
// ============================================
// Stores learned field structures from sample documents
// Used to understand what data to extract from events/transcriptions

enum SchemaDocumentType {
  PUNCH_LIST
  RFI
  DAILY_REPORT
  SAFETY_REPORT
  INSPECTION
  CUSTOM
}

model DocumentSchema {
  id             String             @id @default(uuid())
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // Schema metadata
  name           String             // "Punch List", "RFI Form"
  description    String?            @db.Text
  documentType   SchemaDocumentType @map("document_type")
  version        Int                @default(1)
  isActive       Boolean            @default(true) @map("is_active")

  // Project association (null = global/default schema)
  projectId      String?            @map("project_id")

  // Source document info
  sourceFileName String?            @map("source_file_name")
  sourceFilePath String?            @map("source_file_path")

  // Learned field structure (JSON)
  // Format: [{ name, type, label, description, required, examples }]
  fields         Json               @default("[]")

  // AI analysis metadata
  analysisNotes  String?            @map("analysis_notes") @db.Text
  confidence     Float?             // AI confidence score 0-1

  // Relations
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventSchemaData EventSchemaData[]

  @@index([projectId])
  @@index([documentType])
  @@index([isActive])
  @@map("document_schemas")
}

// ============================================
// EVENT SCHEMA DATA (Extracted Document Fields)
// ============================================
// Stores extracted field values when user applies a document schema to an event
// Enables: Event -> "Apply to Document" -> AI extracts fields -> User edits -> Save

model EventSchemaData {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  eventId       String         @unique @map("event_id")
  schemaId      String         @map("schema_id")

  // Extracted/edited field values as JSON: { "title": "...", "description": "...", etc }
  fieldValues   Json           @map("field_values") @default("{}")

  // Extraction metadata
  extractedAt   DateTime?      @map("extracted_at")
  extractionConfidence Float?  @map("extraction_confidence") // AI confidence 0-1

  // Track manual edits
  lastEditedAt  DateTime?      @map("last_edited_at")
  wasManuallyEdited Boolean    @default(false) @map("was_manually_edited")

  // Generated PDF
  generatedPdfPath String?     @map("generated_pdf_path")
  generatedPdfName String?     @map("generated_pdf_name")
  pdfGeneratedAt   DateTime?   @map("pdf_generated_at")

  // Relations
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  schema        DocumentSchema @relation(fields: [schemaId], references: [id])

  @@index([schemaId])
  @@map("event_schema_data")
}

// ============================================
// FORM TEMPLATES & INSTANCES
// ============================================
// Voice-first form system for Pre-Task Plans, Inspections, etc.

enum FormFieldType {
  YES_NO
  YES_NO_NA
  CHECKBOX
  NUMBER
  TEXT
  DATE
  TIME
  SIGNATURE
  MULTI_SELECT
}

enum FormStatus {
  DRAFT
  IN_PROGRESS
  PENDING_SIGNATURES
  COMPLETED
}

// Form Template - defines the structure of a form
model FormTemplate {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Template metadata
  name          String                    // "Pre-Task Plan", "Fire Pump Inspection"
  description   String?   @db.Text
  category      String?                   // "Safety", "Maintenance", "Inspection"
  language      String    @default("en")  // "en", "tr", etc.
  version       Int       @default(1)
  isActive      Boolean   @default(true) @map("is_active")
  isDefault     Boolean   @default(false) @map("is_default") // System-provided template

  // Project association (null = global/company-wide template)
  projectId     String?   @map("project_id")

  // Original uploaded file (PDF/image)
  originalFileName  String?   @map("original_file_name")
  originalFilePath  String?   @map("original_file_path")

  // Schema: JSON structure defining sections and fields
  // Format: { sections: [{ name, fields: [{ id, label, shortLabel, type, required, unit, options, voiceHints }] }] }
  schema        Json      @default("{\"sections\": []}")

  // AI extraction metadata
  extractedAt   DateTime? @map("extracted_at")
  extractionConfidence Float? @map("extraction_confidence")

  // Creator tracking
  createdById   String?   @map("created_by_id")

  // Relations
  instances     FormInstance[]

  @@index([projectId])
  @@index([category])
  @@index([language])
  @@index([isActive])
  @@index([isDefault])
  @@map("form_templates")
}

// Form Instance - a filled-out form
model FormInstance {
  id            String     @id @default(uuid())
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Template reference
  templateId    String     @map("template_id")

  // Project and location
  projectId     String     @map("project_id")
  location      String?                   // Specific work location
  name          String?                   // Custom name for the form instance

  // Form status
  status        FormStatus @default(DRAFT)
  completedAt   DateTime?  @map("completed_at")

  // Field values: JSON object keyed by field ID
  // Format: { "field_id_1": "yes", "field_id_2": 145, ... }
  data          Json       @default("{}")

  // Voice input tracking
  voiceTranscript   String?   @map("voice_transcript") @db.Text
  voiceRecordingUri String?   @map("voice_recording_uri")

  // Signatures: array of signature objects
  // Format: [{ role, name, signature (base64/url), signedAt }]
  signatures    Json       @default("[]")

  // Sync status for offline support
  syncStatus    String     @default("synced") @map("sync_status") // synced, pending, offline
  lastSyncedAt  DateTime?  @map("last_synced_at")

  // Generated PDF
  generatedPdfPath String?  @map("generated_pdf_path")
  pdfGeneratedAt   DateTime? @map("pdf_generated_at")

  // Creator tracking
  createdById   String?    @map("created_by_id")
  createdByName String?    @map("created_by_name")

  // Relations
  template      FormTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@index([syncStatus])
  @@map("form_instances")
}

// ============================================
// PHOTOS
// ============================================
// Photos can be attached to Events or Daily Logs

model Photo {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // File storage (Cloudinary)
  fileName           String    @map("file_name")           // Original filename
  filePath           String    @map("file_path")           // Cloudinary URL
  cloudinaryPublicId String?   @map("cloudinary_public_id") // For deletion
  mimeType           String    @map("mime_type")           // image/jpeg, image/png
  fileSize           Int       @map("file_size")           // Size in bytes

  // Photo metadata
  caption     String?   @db.Text                 // Optional description
  takenAt     DateTime? @map("taken_at")         // When photo was taken (from EXIF or user input)

  // Associations (a photo belongs to one entity)
  eventId     String?   @map("event_id")
  dailyLogId  String?   @map("daily_log_id")

  // Relations
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dailyLog    DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([dailyLogId])
  @@index([createdAt])
  @@map("photos")
}

// ============================================
// VOICE LISTS (Free-form voice-driven lists)
// ============================================
// Material lists, inventory, procurement, action items, etc.
// Supports continuous voice recording with AI parsing

model VoiceList {
  id                String          @id @default(uuid())
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  // Project association
  projectId         String          @map("project_id")
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // List metadata
  name              String                              // "Panel A Inventory"
  listType          String          @default("material_list") @map("list_type") // material_list, inventory, procurement, action_items
  language          String          @default("en")      // en, tr, es
  status            String          @default("draft")   // draft, completed

  // Voice recording data
  rawTranscript     String?         @map("raw_transcript") @db.Text
  recordingDuration Int?            @map("recording_duration") // seconds

  // Creator tracking
  createdById       String?         @map("created_by_id")
  createdByName     String?         @map("created_by_name")

  // Relations
  sections          VoiceListSection[]
  items             VoiceListItem[]

  @@index([projectId])
  @@index([status])
  @@index([listType])
  @@index([createdAt])
  @@map("voice_lists")
}

model VoiceListSection {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now()) @map("created_at")

  listId      String    @map("list_id")
  name        String
  description String?   @db.Text
  orderIndex  Int       @map("order_index")
  createdVia  String    @default("ui") @map("created_via") // 'voice' or 'ui'

  list        VoiceList @relation(fields: [listId], references: [id], onDelete: Cascade)
  items       VoiceListItem[]

  @@index([listId])
  @@index([orderIndex])
  @@map("voice_list_sections")
}

model VoiceListItem {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  listId            String    @map("list_id")
  sectionId         String?   @map("section_id")

  // Smart hybrid data: AI extracts structured fields when possible
  rawText           String    @map("raw_text")         // Always stored: "2.5 Siyah 10 metre"
  quantity          Float?                              // Extracted: 10
  unit              String?                             // Extracted: "m", "pcs", "kg"
  description       String                              // Extracted/cleaned: "2.5 Siyah cable"
  brandName         String?   @map("brand_name")       // Extracted brand: "Schneider", "ABB"
  category          String?                             // AI-inferred category
  notes             String?   @db.Text                  // Additional context
  orderIndex        Int       @map("order_index")
  transcriptSegment String?   @map("transcript_segment") @db.Text // Original voice segment

  list              VoiceList         @relation(fields: [listId], references: [id], onDelete: Cascade)
  section           VoiceListSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([listId])
  @@index([sectionId])
  @@index([orderIndex])
  @@map("voice_list_items")
}

// ============================================
// MAINTENANCE FORMS (Pump Service System)
// ============================================
// Standalone maintenance form system for pump technicians

enum VisitType {
  BAKIM                   // Maintenance (Bakım)
  SERVIS_SUPERVISORLUK    // Service & Supervision (Servis & Süpervizörlük)
  DEVREYE_ALIM            // Commissioning (Devreye Alım)
}

enum PumpCategory {
  MAIN
  JOCKEY
}

enum PumpModel {
  VERTICAL
  HORIZONTAL
}

enum PumpType {
  ELEKTRIKLI    // Electric
  DIZEL         // Diesel
}

// Maintenance Visit - captures a single site visit
model MaintenanceVisit {
  id             String      @id @default(uuid())
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // User who created the visit
  userId         String      @map("user_id")
  user           User        @relation(fields: [userId], references: [id])

  // Company info (captured first)
  companyName    String?     @map("company_name")    // Firma Adı
  address        String?     @db.Text                // Adres

  // Visit metadata
  visitType      VisitType?  @map("visit_type")      // Selected after company info
  notes          String?     @db.Text

  // Status tracking
  status         String      @default("draft")   // draft, in_progress, completed
  completedAt    DateTime?   @map("completed_at")

  // Relations
  pumps          MaintenancePump[]

  @@index([userId])
  @@index([status])
  @@index([visitType])
  @@index([createdAt])
  @@map("maintenance_visits")
}

// Maintenance Pump - each pump added to a visit
model MaintenancePump {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Parent visit
  visitId       String        @map("visit_id")
  visit         MaintenanceVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  // Pump classification
  pumpCategory  PumpCategory  @map("pump_category")
  pumpModel     PumpModel?    @map("pump_model")     // VERTICAL, HORIZONTAL (for main pumps)
  pumpType      PumpType?     @map("pump_type")      // ELEKTRIKLI, DIZEL (for main pumps)

  // Pump identification details
  brand         String?                              // Marka
  modelNumber   String?       @map("model_number")   // Model
  serialNumber  String?       @map("serial_number")  // Seri No
  photoUrl      String?       @map("photo_url")

  // Ordering
  sortOrder     Int           @default(0) @map("sort_order")

  // Relations
  forms         MaintenancePumpForm[]
  components    MaintenancePumpComponent[]

  @@index([visitId])
  @@index([pumpCategory])
  @@map("maintenance_pumps")
}

// Maintenance Pump Component - each pump has multiple components (e.g., 3)
model MaintenancePumpComponent {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Parent pump
  pumpId        String        @map("pump_id")
  pump          MaintenancePump @relation(fields: [pumpId], references: [id], onDelete: Cascade)

  // Component identification
  componentType String        @map("component_type")  // e.g., "MOTOR", "CONTROLLER", "PUMP_HEAD"
  componentName String?       @map("component_name")

  // ERP integration
  erpTag        String?       @map("erp_tag")         // Tag from ERP system
  erpData       Json?         @map("erp_data")        // Data pulled from ERP

  // Manual entry fields (fallback if no ERP)
  brand         String?
  modelNumber   String?       @map("model_number")
  serialNumber  String?       @map("serial_number")

  // Component-specific data as JSON (flexible for different component types)
  componentData Json?         @map("component_data") @default("{}")

  // Ordering
  sortOrder     Int           @default(0) @map("sort_order")

  @@index([pumpId])
  @@index([componentType])
  @@map("maintenance_pump_components")
}

// Maintenance Pump Form - form instances linked to pumps
model MaintenancePumpForm {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Parent pump
  pumpId         String    @map("pump_id")
  pump           MaintenancePump @relation(fields: [pumpId], references: [id], onDelete: Cascade)

  // Form type (extensible for different checklists)
  formType       String    @map("form_type")  // DIESEL_CHECKLIST, ELECTRIC_CHECKLIST, JOCKEY_CHECKLIST, etc.

  // Form data as JSON (flexible field storage)
  formData       Json?     @map("form_data") @default("{}")

  // Status tracking
  status         String    @default("pending")  // pending, in_progress, completed
  completedAt    DateTime? @map("completed_at")

  // Generated PDF
  generatedPdfPath String?  @map("generated_pdf_path")
  pdfGeneratedAt   DateTime? @map("pdf_generated_at")

  @@index([pumpId])
  @@index([formType])
  @@index([status])
  @@map("maintenance_pump_forms")
}

// ============================================
// VOICE DIARY FEEDBACK
// ============================================
// Feedback from Voice Diary app users

model VoiceDiaryFeedback {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Feedback content
  text        String    @db.Text

  // User info (optional - can be anonymous)
  userId      String?   @map("user_id")
  userName    String?   @map("user_name")
  userEmail   String?   @map("user_email")

  // Audio file if feedback was voice recorded
  audioUrl    String?   @map("audio_url")

  // Status tracking
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("voice_diary_feedback")
}

// ============================================
// VOICE DIARY ENTRIES
// ============================================
// Tracks all voice diary entries across users

model VoiceDiaryEntry {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // User info
  userId         String    @map("user_id")
  userName       String?   @map("user_name")

  // Project info
  projectId      String?   @map("project_id")
  projectName    String?   @map("project_name")

  // Entry content
  transcriptText String?   @map("transcript_text") @db.Text
  cleanedText    String?   @map("cleaned_text") @db.Text
  category       String?

  // Audio file
  audioUrl       String?   @map("audio_url")
  audioDuration  Int?      @map("audio_duration") // seconds

  @@index([userId])
  @@index([projectId])
  @@index([category])
  @@index([createdAt])
  @@map("voice_diary_entries")
}
