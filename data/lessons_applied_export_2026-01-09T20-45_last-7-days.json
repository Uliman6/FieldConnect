    {
      "event": {
        "id": "qtkfuqdljflmk7cem9u",
        "project_id": "t2n81sremiemji271r4",
        "created_at": "2026-01-09T20:42:37.506Z",
        "local_audio_uri": "file:///var/mobile/Containers/Data/Application/171121ED-FC13-410A-8985-271D6F0AC7D8/Documents/audio/recording_1767991353253_tw6q6ftpr99mk7ceizp.m4a",
        "transcript_text": "Our project is located very close to the Levi's Stadium, which is where the Super Bowl is going to be held this year, which means we won't be able to finish or do any work during this time because of Santa Clara County's request. So we're going to have to shut down all landscaping operations for the month of February, which means we're going to have to come back in March to do all this work.",
