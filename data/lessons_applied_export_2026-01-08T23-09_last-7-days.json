        {
          "id": "14y3s6qlu0tmk5z25ie",
          "section_key": "master_recording",
          "local_audio_uri": "file:///var/mobile/Containers/Data/Application/171121ED-FC13-410A-8985-271D6F0AC7D8/Documents/audio/recording_1767908473385_sk6kkl735rqmk5z24h5.m4a",
          "transcript_text": "The weather today was rainy and 50 degrees. We had to stop working. DPR Concrete had to stop working four hours into their shift. They will have to come back Saturday for overtime to complete this work. They had four guys working four hours. We had SNS Steel working on the northwest side of the building erecting steel beams and columns. They had five guys working eight hours. Special Inspector Jason Kim was on site inspecting welds that SNS was installing. We had AMB Landscaping working on the southeast side of the exterior bringing in soil, digging soil as well as putting in shrubs and water meters for irrigation. They had three guys working ten hours. We also had EIG Electric working the electrical room for the most part and lighting control. They had six guys working eight hours. We also had electrical inspection in the electrical room so two of their guys were supporting the inspection.",
          "status": "transcribed",
          "created_at": "2026-01-08T21:41:14.726Z"
